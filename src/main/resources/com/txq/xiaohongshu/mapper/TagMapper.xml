<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.txq.xiaohongshu.mapper.TagMapper">

    <resultMap id="TagResultMap" type="com.txq.xiaohongshu.pojo.Tag">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="post_count" property="postCount"/>
        <result column="follow_count" property="followCount"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="tagColumns">
        id, name, description, cover_url,
        post_count, follow_count, status, created_at
    </sql>

    <select id="selectAll" resultMap="TagResultMap">
        SELECT <include refid="tagColumns"/>
        FROM tags
        WHERE status = 1
        ORDER BY post_count DESC
    </select>

    <!-- ==================== 管理端 ==================== -->

    <select id="selectAdminList" resultMap="TagResultMap">
        SELECT <include refid="tagColumns"/>
        FROM tags
        <where>
            <if test="keyword != null and keyword != ''">
                AND name LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        <choose>
            <when test="sortBy == 'followCount'">
                ORDER BY follow_count DESC
            </when>
            <when test="sortBy == 'createdAt'">
                ORDER BY created_at DESC
            </when>
            <otherwise>
                ORDER BY post_count DESC
            </otherwise>
        </choose>
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countAdminList" resultType="long">
        SELECT COUNT(*) FROM tags
        <where>
            <if test="keyword != null and keyword != ''">
                AND name LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </select>

    <insert id="insertTag" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tags (name, description, cover_url)
        VALUES (#{name}, #{description}, #{coverUrl})
    </insert>

    <update id="updateTag">
        UPDATE tags
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="coverUrl != null">cover_url = #{coverUrl},</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateTagStatus">
        UPDATE tags SET status = #{status} WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="TagResultMap">
        SELECT <include refid="tagColumns"/> FROM tags WHERE id = #{id}
    </select>

</mapper>